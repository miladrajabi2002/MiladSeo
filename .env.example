# Database
DATABASE_URL="file:./prisma/dev.db"

# Auth
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH=""          # Run: make hash-password PASSWORD=xxx (escape $ as \$ — the make target does this for you)
NEXTAUTH_SECRET=""              # Run: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth2
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
GOOGLE_REFRESH_TOKEN=""         # Filled after first OAuth login (or auto-saved to DB)

# PageSpeed Insights (optional — works without a key on the shared quota;
# create a free key in Google Cloud Console > APIs > PageSpeed Insights API
# for a dedicated 25k/day quota)
PAGESPEED_API_KEY=""

# App
PORT=3000
NODE_ENV=production
NEXT_PUBLIC_APP_NAME="SEO Dashboard"
