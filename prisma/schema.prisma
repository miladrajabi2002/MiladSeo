generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id           Int               @id @default(autoincrement())
  name         String
  domain       String
  gscProperty  String // e.g. "sc-domain:example.com" or "https://example.com/"
  location     String            @default("Iran")
  color        String? // optional hex accent for the project's card/avatar
  ga4PropertyId String? // Google Analytics 4 property id, e.g. "properties/123456789"
  sheetId      String? // Google Sheet id for the Live Sheet export
  createdAt    DateTime          @default(now())
  lastSyncAt   DateTime?
  keywords     Keyword[]
  alerts       Alert[]
  annotations  Annotation[]
  shareLinks   ShareLink[]
  indexChecks  UrlIndexStatus[]
  indexHistory UrlIndexHistory[]
  speedResults PageSpeedResult[]
  competitors  Competitor[]
}

model Keyword {
  id        Int              @id @default(autoincrement())
  text      String
  urlPath   String?
  group     String?
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  rankings  KeywordRanking[]
  createdAt DateTime         @default(now())

  @@index([projectId])
}

model KeywordRanking {
  id          Int      @id @default(autoincrement())
  keyword     Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  keywordId   Int
  position    Float?
  clicks      Int?
  impressions Int?
  ctr         Float?
  device      String // "desktop" or "mobile"
  date        DateTime @default(now())

  @@index([keywordId, device, date])
}

model Alert {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  keyword   String
  type      String // "jumped" or "dropped"
  group     String?
  prevPos   Float
  nowPos    Float
  delta     Float
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([projectId, isRead])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  projectId Int
  status    String // "success" | "error"
  message   String?
  syncedAt  DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// Timeline notes ("changed titles on this date") rendered as markers on charts
model Annotation {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  date      DateTime
  title     String
  note      String?
  createdAt DateTime @default(now())

  @@index([projectId, date])
}

// Read-only public dashboard tokens; deleting a row revokes the link
model ShareLink {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([projectId])
}

// Cached URL Inspection API results, one row per page URL (latest snapshot)
model UrlIndexStatus {
  id            Int       @id @default(autoincrement())
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     Int
  urlPath       String
  verdict       String // PASS | FAIL | NEUTRAL | PARTIAL | VERDICT_UNSPECIFIED
  coverageState String?
  indexingState String?
  robotsState   String?
  fetchState    String?
  lastCrawlTime DateTime?
  googleCanonical String?
  checkedAt     DateTime  @default(now())

  @@unique([projectId, urlPath])
  @@index([projectId])
}

// Append-only history of index verdicts so coverage trends can be charted
model UrlIndexHistory {
  id            Int      @id @default(autoincrement())
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     Int
  urlPath       String
  verdict       String
  coverageState String?
  day           String // "yyyy-MM-dd" — one snapshot per URL per day
  checkedAt     DateTime @default(now())

  @@unique([projectId, urlPath, day])
  @@index([projectId, day])
}

// A competitor domain (or the project's own site, isSelf=true) whose SERP
// positions are tracked head-to-head for a set of keywords.
model Competitor {
  id        Int                 @id @default(autoincrement())
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  domain    String
  label     String?
  isSelf    Boolean             @default(false)
  createdAt DateTime            @default(now())
  rankings  CompetitorRanking[]

  @@unique([projectId, domain])
  @@index([projectId])
}

// One scraped SERP position for a competitor on a keyword, per day.
model CompetitorRanking {
  id           Int        @id @default(autoincrement())
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  competitorId Int
  keyword      String
  position     Int? // null = not found in the scraped results
  day          String // "yyyy-MM-dd"
  checkedAt    DateTime   @default(now())

  @@unique([competitorId, keyword, day])
  @@index([competitorId])
}

// PageSpeed Insights results — one row per page URL + strategy + day so the
// latest score is a cache AND the daily history can be charted over time.
model PageSpeedResult {
  id          Int      @id @default(autoincrement())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   Int
  urlPath     String
  strategy    String // "mobile" | "desktop"
  score       Int // performance score 0-100
  lcpMs       Float?
  cls         Float?
  inpMs       Float?
  fcpMs       Float?
  ttfbMs      Float?
  day         String // "yyyy-MM-dd"
  checkedAt   DateTime @default(now())

  @@unique([projectId, urlPath, strategy, day])
  @@index([projectId])
}
