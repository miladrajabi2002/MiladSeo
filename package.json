{
  "name": "seo-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Personal SEO keyword rank tracker dashboard powered by Google Search Console",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && next build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@prisma/client": "^5.22.0",
    "@types/jalaali-js": "^1.2.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.11.9",
    "googleapis": "^144.0.0",
    "jalaali-js": "^1.2.8",
    "lucide-react": "^0.452.0",
    "next": "^14.2.15",
    "next-auth": "^4.24.10",
    "next-themes": "^0.3.0",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
